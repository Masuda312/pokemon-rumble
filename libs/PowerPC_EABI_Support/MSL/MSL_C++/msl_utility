struct any_conversion {
    template <typename T> any_conversion(const volatile T &);
    template <typename T> any_conversion(T &);
};

template <typename T> struct checker {
    static two _m_check(any_conversion...);
    static char _m_check(T, int);
};

template <typename From, typename To> struct is_convertible_basic_impl {
    static From _m_from;
    static bool const value =
        sizeof(detail::checker<To>::_m_check(_m_from, 0)) == 1;
};

template <typename From, typename To> struct is_convertible_impl {
    typedef typename add_reference<From>::type ref_type;
    static const bool value =
        _and<detail::is_convertible_basic_impl<ref_type, To>,
             _not<is_array<To> > >::value;
};

} // namespace detail

template <class From, class To> struct is_convertible {
    static const bool value = detail::is_convertible_impl<From, To>::value;
};

